DEBUG=on
ENV=dev

# Main Settings
SECRET_KEY=django-insecure-dev-secret-key
SITE_URL=http://localhost:8000
ADMIN_URL=admin/
DATABASE_URL=postgres://bwd:bwd@db:5432/bwd
####  run the following to code on the next line to get the secret key, if you don't have one already.
##### python -c 'import random; result = "".join([random.choice("abcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*(-_=+)") for i in range(50)]); print(result)'

ALLOWED_HOSTS=localhost,127.0.0.1

# Sentry
SENTRY_DSN=''
# Backwards-compatible alias still works, but prefer SENTRY_DSN.
dsn=''
LOGFIRE_TOKEN=''
# Omit this in production to use the ENV=prod default, or set it explicitly.
SENTRY_ENABLED=false
SENTRY_ERROR_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_IMPORTANT_TRACES_SAMPLE_RATE=1.0
SENTRY_BACKGROUND_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.2
SENTRY_ENABLE_LOGS=true
SENTRY_LOG_LEVEL=WARNING
SENTRY_BREADCRUMB_LOG_LEVEL=INFO
SENTRY_ENABLE_METRICS=true
SENTRY_SEND_DEFAULT_PII=false
SENTRY_INCLUDE_LOCAL_VARIABLES=false
SENTRY_INCLUDE_AI_PROMPTS=false
SENTRY_STREAM_GEN_AI_SPANS=true
SENTRY_MAX_REQUEST_BODY_SIZE=small
SENTRY_TRACE_PROPAGATION_TARGETS="http://localhost:8000"

# PostHog
POSTHOG_ENABLED=false
# The project API key is public; production falls back to the Built with Django key in settings.py.
POSTHOG_API_KEY="your-posthog-project-api-key"
POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_UI_HOST="https://us.posthog.com"
POSTHOG_PERSONAL_API_KEY=""

# EmailOctopus
EMAILOCTOPUS_API=''
OCTO_LIST_ID=''
BUTTONDOWN_API_TOKEN=''

# Email
MAILGUN_API_KEY=""

# AI
OPENROUTER_API_KEY=test-openrouter-key
PYDANTIC_AI_MODEL="openrouter:deepseek/deepseek-v4-flash"

# Stripe
STRIPE_LIVE_SECRET_KEY=""
STRIPE_TEST_SECRET_KEY=""
STRIPE_LIVE_MODE=false
WEBHOOK_UUID=""

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Storage
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=builtwithdjango
AWS_SECRET_ACCESS_KEY=builtwithdjango

# Workers/cache
REDIS_URL=redis://:bwd@redis:6379/0

# External APIs
SCREENSHOT_API_KEY=""
TJ_ALERTS_API_KEY=""
JINA_READER_API_KEY=""
GEMINI_API_KEY=""
READWISE_API_TOKEN=""

# Twitter/X import helpers
TWITTER_USERNAME=""
TWITTER_PASSWORD=""
TWITTER_EMAIL=""
